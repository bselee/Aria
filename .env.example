# Dashboard API bearer token. Required — middleware blocks all /api/dashboard/*
# requests without a matching `Authorization: Bearer <token>` header.
# Generate a strong random value, e.g.:
#   openssl rand -hex 32
DASHBOARD_API_TOKEN=

# Shared secret for the GitHub webhook (Settings → Webhooks → Secret).
# Must exactly match the value configured on the GitHub repo webhook;
# requests with a missing or invalid HMAC signature are rejected.
GITHUB_WEBHOOK_SECRET=
